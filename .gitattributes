# Set the default behavior to automatically normalize line endings.
* text=auto

# Declare files that should always have LF line endings on check-in.
*.js text
*.jsx text
*.ts text
*.tsx text
*.json text
*.css text
*.scss text
*.html text
*.md text
*.gitignore text
*.gitattributes text
*.yml text
*.yaml text

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.mp4 binary
*.mp3 binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
